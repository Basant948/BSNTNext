@using BSNTNext.Application.Dtos.Nav
@{
    var navItems = ViewBag.ModuleNav as List<NavItemDto> ?? new();
    var isAdmin = ViewBag.IsAdmin is bool b && b;
    var currentKey = ViewBag.CurrentNavKey as string ?? "";
    var dashboard = navItems.FirstOrDefault(n => n.Url.Contains("Dashboard"));
    var rest = navItems.Where(n => n != dashboard).GroupBy(n => n.Group).ToList();

    var moduleTitle = ViewBag.ModuleTitle as string ?? "Module";
    var moduleIcon = ViewBag.ModuleIcon as string ?? "fa-solid fa-th-large";
    var roleMgmtUrl = ViewBag.RoleManagementUrl as string ?? "#";

    string NavClass(bool active, bool isSub = false) =>
        $"nav-link d-flex align-items-center gap-2 text-decoration-none px-3 py-2 {(isSub ? "ps-4" : "")} {(active ? "nav-active text-white fw-semibold" : "text-white-50")}";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @moduleTitle | EhrNext</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        body { background: #f0f4f8; }
        .sidebar {
            width: 240px;
            background: #1a3a5c;
            min-height: calc(100vh - 60px);
            overflow-y: auto;
        }
        .nav-link {
            border-left: 3px solid transparent;
            transition: .2s ease;
        }
        .nav-link:hover {
            background: rgba(255,255,255,.08);
            color: #fff !important;
        }
        .nav-active {
            background: rgba(255,255,255,.15);
            border-left-color: #f0a500;
        }
        .section-label {
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: rgba(255,255,255,.35);
        }
        .module-icon-box {
            width: 38px;
            height: 38px;
            background: rgba(255,255,255,.15);
            border-radius: 8px;
        }
    </style>
</head>
<body class="m-0">

    <div class="d-flex" style="height:calc(100vh - 60px);">

        <aside class="sidebar d-flex flex-column flex-shrink-0">

            <div class="p-3 border-bottom border-light border-opacity-10">
                <div class="d-flex align-items-center gap-2">
                    <div class="module-icon-box d-flex justify-content-center align-items-center">
                        <i class="@moduleIcon text-white"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-white small">@moduleTitle</div>
                        <div class="text-white-50" style="font-size:.7rem;">Management System</div>
                    </div>
                </div>
            </div>

            <nav class="flex-grow-1 py-2">

                @if (dashboard != null)
                {
                    <a href="@dashboard.Url" class="@NavClass(dashboard.Key == currentKey)">
                        <i class="@dashboard.Icon"></i>
                        <span>@dashboard.Label</span>
                    </a>
                }

                @foreach (var group in rest)
                {
                    <div class="section-label px-3 pt-3 pb-1">@group.Key</div>

                    @foreach (var item in group)
                    {
                        <a href="@item.Url" class="@NavClass(item.Key == currentKey)">
                            <i class="@item.Icon"></i>
                            <span>@item.Label</span>
                        </a>
                    }
                }

                @if (isAdmin)
                {
                    <div class="section-label px-3 pt-3 pb-1">Admin</div>

                    <button id="adminMenuBtn"
                            onclick="toggleAdminMenu()"
                            class="btn w-100 text-start text-white-50 border-0 rounded-0 d-flex align-items-center gap-2 px-3 py-2">
                        <i class="fa-solid fa-user-gear"></i>
                        <span class="flex-grow-1">Administrative</span>
                        <i id="adminChevron" class="fa-solid fa-chevron-down small"></i>
                    </button>

                    <div id="adminSubMenu" class="d-none">
                        <a href="@roleMgmtUrl" class="@NavClass(currentKey == "admin.rolemgmt", true)">
                            <i class="fa-solid fa-shield-halved"></i>
                            <span>Role Management</span>
                        </a>
                    </div>
                }

            </nav>

            <div class="p-3 border-top border-light border-opacity-10">
                <a href="/" class="text-decoration-none text-white-50 small d-flex align-items-center gap-2">
                    <i class="fa-solid fa-arrow-left"></i>
                    <span>Back to Dashboard</span>
                </a>
            </div>

        </aside>

        <main class="flex-grow-1 overflow-auto bg-light-subtle">
            @RenderBody()
        </main>

    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>

    <script>
        function toggleAdminMenu() {
            const menu = document.getElementById('adminSubMenu');
            const chevron = document.getElementById('adminChevron');
            const btn = document.getElementById('adminMenuBtn');

            menu.classList.toggle('d-none');
            const isOpen = !menu.classList.contains('d-none');

            chevron.style.transform = isOpen ? 'rotate(180deg)' : 'rotate(0deg)';
            btn.classList.toggle('text-white', isOpen);
        }
    </script>

    @if (currentKey == "admin.rolemgmt")
    {
        <script>
            document.addEventListener('DOMContentLoaded', toggleAdminMenu);
        </script>
    }

    @RenderSection("Scripts", required: false)
</body>
</html>
