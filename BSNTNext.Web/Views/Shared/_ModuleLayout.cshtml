@using BSNTNext.Application.Dtos.Nav
@{
    var navItems = ViewBag.ModuleNav as List<NavItemDto> ?? new();
    var isAdmin = ViewBag.IsAdmin is bool b && b;
    var currentKey = ViewBag.CurrentNavKey as string ?? "";
    var dashboard = navItems.FirstOrDefault(n => n.Url.Contains("Dashboard"));
    var rest = navItems.Where(n => n != dashboard).GroupBy(n => n.Group).ToList();

    // Per-module values set by BaseModuleController.SetNavAsync()
    var moduleTitle = ViewBag.ModuleTitle as string ?? "Module";
    var moduleIcon = ViewBag.ModuleIcon as string ?? "fa-solid fa-th-large";
    var moduleColor = ViewBag.ModuleColor as string ?? "#2A6EBB";
    var roleMgmtUrl = ViewBag.RoleManagementUrl as string ?? "#";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – @moduleTitle | EhrNext</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body style="margin:0;background:#f0f4f8;">

   

    <div style="display:flex;height:calc(100vh - 60px);">
        <aside style="width:240px;background:#1a3a5c;display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto;">
            <div style="padding:18px 16px 14px;border-bottom:1px solid rgba(255,255,255,0.1);">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:38px;height:38px;background:rgba(255,255,255,0.15);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                        <i class="@moduleIcon" style="color:#fff;font-size:1.1rem;"></i>
                    </div>
                    <div>
                        <div style="color:#fff;font-weight:700;font-size:0.92rem;">@moduleTitle</div>
                        <div style="color:rgba(255,255,255,0.45);font-size:0.7rem;">Management System</div>
                    </div>
                </div>
            </div>

            <nav style="padding:8px 0;flex:1;">
                @if (dashboard != null)
                {
                    bool da = dashboard.Key == currentKey;
                    <a href="@dashboard.Url" style="display:flex;align-items:center;gap:11px;padding:10px 16px;text-decoration:none;background:@(da ? "rgba(255,255,255,0.15)" : "transparent");border-left:3px solid @(da ? "#f0a500" : "transparent");color:@(da ? "#fff" : "rgba(255,255,255,0.65)");">
                        <i class="@dashboard.Icon" style="width:17px;text-align:center;font-size:0.9rem;"></i>
                        <span style="font-size:0.86rem;font-weight:@(da ? "600" : "400");">@dashboard.Label</span>
                    </a>
                }
                @foreach (var g in rest)
                {
                    <div style="padding:10px 16px 4px;font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:rgba(255,255,255,0.35);">@g.Key</div>
                    @foreach (var item in g)
                    {
                        bool ia = item.Key == currentKey;
                        <a href="@item.Url" style="display:flex;align-items:center;gap:11px;padding:9px 16px 9px 22px;text-decoration:none;background:@(ia ? "rgba(255,255,255,0.15)" : "transparent");border-left:3px solid @(ia ? "#f0a500" : "transparent");color:@(ia ? "#fff" : "rgba(255,255,255,0.6)");">
                            <i class="@item.Icon" style="width:16px;text-align:center;font-size:0.85rem;"></i>
                            <span style="font-size:0.84rem;font-weight:@(ia ? "600" : "400");">@item.Label</span>
                        </a>
                    }
                }
                @if (isAdmin)
                {
                    <div style="padding:10px 16px 4px;font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:rgba(255,255,255,0.35);">Admin</div>
                    <button onclick="toggleAdminMenu()" id="adminMenuBtn" style="display:flex;align-items:center;gap:11px;width:100%;padding:9px 16px 9px 22px;background:transparent;border:none;border-left:3px solid transparent;color:rgba(255,255,255,0.6);text-align:left;cursor:pointer;">
                        <i class="fa-solid fa-user-gear" style="width:16px;text-align:center;font-size:0.85rem;"></i>
                        <span style="font-size:0.84rem;flex:1;">Administrative</span>
                        <i class="fa-solid fa-chevron-down" id="adminChevron" style="font-size:0.65rem;transition:transform 0.2s;"></i>
                    </button>
                    <div id="adminSubMenu" style="display:none;">
                        <a href="@roleMgmtUrl" style="display:flex;align-items:center;gap:11px;padding:9px 16px 9px 38px;text-decoration:none;background:@(currentKey == "admin.rolemgmt" ? "rgba(255,255,255,0.15)" : "transparent");border-left:3px solid @(currentKey == "admin.rolemgmt" ? "#f0a500" : "transparent");color:@(currentKey == "admin.rolemgmt" ? "#fff" : "rgba(255,255,255,0.55)");">
                            <i class="fa-solid fa-shield-halved" style="width:16px;text-align:center;font-size:0.82rem;"></i>
                            <span style="font-size:0.83rem;">Role Management</span>
                        </a>
                    </div>
                }
            </nav>

            <div style="padding:12px 16px;border-top:1px solid rgba(255,255,255,0.08);">
                <a href="/" style="display:flex;align-items:center;gap:9px;text-decoration:none;color:rgba(255,255,255,0.45);font-size:0.8rem;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.45)'">
                    <i class="fa-solid fa-arrow-left"></i>Back to Dashboard
                </a>
            </div>
        </aside>

        <main style="flex:1;overflow-y:auto;background:#f0f4f8;">@RenderBody()</main>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleAdminMenu() {
        const m = document.getElementById('adminSubMenu'),
        c = document.getElementById('adminChevron'),
        b = document.getElementById('adminMenuBtn');
        const open = m.style.display === 'none';
        m.style.display = open ? 'block' : 'none';
        c.style.transform = open ? 'rotate(180deg)' : '';
        b.style.color = open ? 'rgba(255,255,255,0.85)' : 'rgba(255,255,255,0.6)';
        }
        @if (currentKey == "admin.rolemgmt")
        {
            <text>document.addEventListener('DOMContentLoaded', () => toggleAdminMenu());</text>
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
