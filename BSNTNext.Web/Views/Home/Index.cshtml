@model List<BSNTNext.Domain.Entity.AppModule>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<style>
    body {
        margin: 0 !important;
        padding: 0 !important;
    }

    .full-width-bg {
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        background-color: #0d6efd;
        min-height: 100vh;
        padding: 30px;
    }

    .module-card {
        transition: all 0.25s ease;
        border-radius: 10px;
    }

        .module-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        }
</style>

<div class="full-width-bg">

    @if (Model?.Any() == true)  //@if (Model != null && Model.Any()) ---- Same
    {
        <div class="row g-4">
            @foreach (var module in Model)
            {
                <div class="col-md-3">
                    <a href="/@module.AreaName/Dashboard/Index"
                           class="card module-card text-center shadow-sm text-decoration-none h-100">
                        <div class="card-body">
                            <div class="fs-1 text-primary mb-3">
                                @Html.Raw(module.IconSvg)
                            </div>
                            <h6 class="fw-semibold text-dark">
                                @module.DisplayName
                            </h6>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 text-white">
            <i class="bi bi-lock fs-1 d-block mb-3"></i>
            <h5>No Modules Assigned</h5>
            <p>You don't have access to any modules yet.</p>
        </div>
    }

</div>