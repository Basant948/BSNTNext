@using BSNTNext.Application.Dtos.Auth
@model ForgotPasswordDto
@{
    ViewData["Title"] = "Forgot Password";
}

<h2>Forgot Password</h2>
<p>Enter your email and we'll send you a reset link.</p>

<form asp-controller="Account" asp-action="ForgotPassword" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All"></div>

    <label asp-for="Email"></label>
    <input asp-for="Email" placeholder="Enter your email" />
    <span asp-validation-for="Email"></span>

    <button type="submit">Send Reset Link</button>
</form>

<a asp-controller="Account" asp-action="Login">Back to Login</a>