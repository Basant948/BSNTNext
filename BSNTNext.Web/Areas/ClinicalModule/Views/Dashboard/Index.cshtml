@using BSNTNext.Application.Dtos.Nav
@{
    Layout = "~/Views/Shared/_ModuleLayout.cshtml";
    ViewData["Title"] = "Clinical Dashboard";
    var navItems = ViewBag.ModuleNav as List<NavItemDto> ?? new();
}
<div style="padding:32px;">
    <div style="background:linear-gradient(135deg,#198754,#0f5132);border-radius:12px;padding:28px 32px;color:#fff;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between;">
        <div>
            <h4 style="font-weight:700;margin-bottom:4px;"><i class="fa-solid fa-user-doctor me-2" style="opacity:0.8;"></i>Clinical Module</h4>
            <p style="opacity:0.75;margin:0;font-size:0.9rem;">Welcome, @(ViewBag.UserFullName ?? "User"). You have access to @navItems.Count menu items.</p>
        </div>
        <div style="font-size:3rem;opacity:0.3;"><i class="fa-solid fa-user-doctor"></i></div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px;">
        @foreach (var item in navItems.Where(n => !n.Url.Contains("Dashboard")))
        {
            <a href="@item.Url" style="background:#fff;border-radius:10px;padding:20px 16px;text-align:center;text-decoration:none;color:#333;box-shadow:0 2px 8px rgba(0,0,0,0.07);border:2px solid transparent;display:block;" onmouseover="this.style.borderColor='#198754'" onmouseout="this.style.borderColor='transparent'">
                <i class="@item.Icon" style="font-size:2rem;color:#198754;margin-bottom:10px;display:block;"></i>
                <span style="font-size:0.84rem;font-weight:600;">@item.Label</span>
            </a>
        }
    </div>
</div>
